rules_version = '2';

// Crosby Development — Firebase Storage rules.
//
// Lease PDFs in this bucket are surfaced on the dashboard via per-file DOWNLOAD
// TOKENS (the ?token=… URLs in the leaseDocs collection). Download-token URLs
// bypass these rules, so the dashboard links keep working while rule-based access
// is denied: the bucket is not publicly readable or listable, and clients cannot
// write. Uploads happen out-of-band via the Admin SDK / gsutil (which also bypass
// rules). This replaces the console's temporary test-mode rules (which allowed
// public writes and expire).
service firebase.storage {
  match /b/{bucket}/o {
    // Marketing assets (approved flyers) for the unauthenticated Leasing area —
    // public read + size/type-limited public write, mirroring the public
    // marketing collections in Firestore. Everything else stays locked.
    match /marketing/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource == null
                   || (request.resource.size < 15 * 1024 * 1024
                       && request.resource.contentType.matches('application/pdf|image/.*'));
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
