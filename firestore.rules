rules_version = '2';

// Crosby Development — Agent Dashboard Firestore rules.
//
// Single-operator access model: only the allowlisted, email-verified operator
// account may read or write ANY document. The data contains tenant PII
// (names, phones, emails, rents), so there is no public read.
//
// To add more operators later: switch isOperator() to check a custom claim
// (request.auth.token.operator == true) or an allowlist/{email} lookup doc.

service cloud.firestore {
  match /databases/{database}/documents {

    function isOperator() {
      return request.auth != null
          && request.auth.token.email_verified == true
          && request.auth.token.email == "thomas.ryan.crosby@gmail.com";
    }

    // Shared leasing/marketing state — promoted suites and their flyer media.
    // The dashboard runs unauthenticated (AUTH_ENABLED = false), so these two
    // collections allow public WRITE as well as read; that is what makes the
    // Leasing area multi-user / cross-device. Firestore caps each doc at ~1 MB,
    // so each photo is stored as its own marketingMedia doc. To lock this down
    // later, re-enable auth and change write back to isOperator().
    match /marketing/{doc} {
      allow read, write: if true;
    }
    match /marketingMedia/{doc} {
      allow read, write: if true;
    }

    // ⚠ TEMPORARY: public read for the unauthenticated dashboard preview
    // (firebase-config.js AUTH_ENABLED = false). This exposes ALL tenant PII
    // publicly. To re-secure, restore `allow read: if isOperator();` and set
    // AUTH_ENABLED = true, then redeploy these rules.
    match /{document=**} {
      allow read: if true;
      allow write: if isOperator();
    }
  }
}
